# ============================================
# BUJA Core Platform - Shared Environment Template
# ============================================
# Copy to: .env
# This file is intentionally split in usage:
# - backend/.env: backend runtime (fastapi)
# - .env.local: frontend runtime (Next.js client env)

# ============================================
# Backend / Common
# ============================================
APP_NAME=BUJA Core Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

# ============================================
# Database (Shared DB Server - multi-project)
# ============================================
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
DATABASE_SCHEMA=buja_app

# ============================================
# Infra
# ============================================
REDIS_URL=redis://localhost:6379/0
STARTUP_WITHOUT_REDIS=true

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<NEO4J_PASSWORD>

# ============================================
# Security (Required)
# ============================================
JWT_SECRET_KEY=<JWT_SECRET>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

JOB_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<YOUR_PRIVATE_KEY>\n-----END PRIVATE KEY-----"
JOB_SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<YOUR_PUBLIC_KEY>\n-----END PUBLIC KEY-----"

# ============================================
# Services
# ============================================
PINECONE_API_KEY=<PINECONE_API_KEY>
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
TAVILY_API_KEY=<TAVILY_API_KEY>

LANGFUSE_PUBLIC_KEY=<LANGFUSE_PUBLIC_KEY>
LANGFUSE_SECRET_KEY=<LANGFUSE_SECRET_KEY>
LANGFUSE_HOST=https://cloud.langfuse.com

TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_WEBHOOK_URL=<TELEGRAM_WEBHOOK_URL>

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Frontend (Next.js public variables)
# ============================================
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_LANGFUSE_PROJECT_ID=<LANGFUSE_PROJECT_ID>
